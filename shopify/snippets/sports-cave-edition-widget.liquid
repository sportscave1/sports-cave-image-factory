{% liquid
  assign sc_total = product.metafields.sports_cave.edition_total.value | default: 100
  assign sc_next = product.metafields.sports_cave.next_edition_number.value
  assign sc_remaining = product.metafields.sports_cave.remaining_count.value
  assign sc_status = product.metafields.sports_cave.edition_status.value
  assign sc_display_text = product.metafields.sports_cave.edition_display_text.value

  if sc_display_text == blank
    if sc_status == 'sold_out'
      assign sc_display_text = 'Sold Out Archive'
    elsif sc_status == 'final_editions' and sc_remaining != blank
      assign sc_display_text = 'Final Editions — Only ' | append: sc_remaining | append: ' Remaining'
    elsif sc_next != blank
      assign padded_next = sc_next

      if sc_next < 10
        assign padded_next = '00' | append: sc_next
      elsif sc_next < 100
        assign padded_next = '0' | append: sc_next
      endif

      assign sc_display_text = 'Next Available Edition #' | append: padded_next | append: '/' | append: sc_total
    else
      assign sc_display_text = 'Numbered Edition of ' | append: sc_total
    endif
  endif
%}

<!-- SPORTS CAVE • LIMITED RUN COLLECTOR SEAL -->
<div class="sc-collector-pill-wrap">
  <div class="sc-collector-pill" role="note" aria-label="{{ sc_display_text | escape }}">
    <div class="sc-collector-pill__seal" aria-hidden="true">
      <img
        src="https://cdn.shopify.com/s/files/1/0722/2332/6515/files/collector-series-icon-thumbnail-optimized-18kb.webp?v=1781045748"
        alt=""
        loading="lazy"
        decoding="async"
        fetchpriority="low"
        width="66"
        height="66"
      >
    </div>

    <div class="sc-collector-pill__text">
      {{ sc_display_text | escape }}
    </div>
  </div>
</div>

<style>
  .sc-collector-pill-wrap {
    width: 100%;
    display: block;
    margin: 6px 0 18px;
    padding: 0;
    box-sizing: border-box;
  }

  .sc-collector-pill,
  .sc-collector-pill * {
    box-sizing: border-box;
  }

  .sc-collector-pill {
    position: relative;
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 100%;
    min-height: 36px;
    padding: 0;
    border-radius: 10px;
    background: transparent;
    border: none;
    box-shadow: none;
    font-family: inherit;
    overflow: visible;
  }

  .sc-collector-pill::before {
    content: "";
    position: absolute;
    inset: 0 0 0 33px;
    border-radius: 10px;
    border: 1px solid rgba(212, 165, 76, 0.62);
    background:
      linear-gradient(180deg, rgba(245, 242, 234, 0.055), rgba(245, 242, 234, 0) 55%),
      linear-gradient(90deg, rgba(212, 165, 76, 0.18), rgba(212, 165, 76, 0.055) 39%, rgba(11, 11, 13, 0) 82%),
      #0B0B0D;
    box-shadow:
      0 7px 14px rgba(0, 0, 0, 0.16),
      0 1px 0 rgba(212, 165, 76, 0.22),
      inset 0 0 0 1px rgba(245, 242, 234, 0.032),
      inset 0 1px 0 rgba(245, 242, 234, 0.08),
      inset 0 -1px 0 rgba(212, 165, 76, 0.14);
    pointer-events: none;
  }

  .sc-collector-pill::after {
    content: "";
    position: absolute;
    left: 98px;
    right: 14px;
    bottom: 5px;
    height: 1px;
    background: linear-gradient(
      90deg,
      rgba(212, 165, 76, 0),
      rgba(212, 165, 76, 0.34),
      rgba(212, 165, 76, 0)
    );
    opacity: 0.38;
    pointer-events: none;
  }

  .sc-collector-pill__seal {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 73px;
    height: 73px;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    flex: 0 0 auto;
  }

  .sc-collector-pill__seal::before {
    content: "";
    position: absolute;
    width: 53px;
    height: 53px;
    border-radius: 50%;
    background:
      radial-gradient(circle, rgba(245, 242, 234, 0.10) 0%, rgba(11, 11, 13, 0.92) 58%, rgba(11, 11, 13, 0) 72%);
    box-shadow:
      0 0 0 1px rgba(212, 165, 76, 0.22),
      0 7px 16px rgba(0, 0, 0, 0.28);
    z-index: -1;
  }

  .sc-collector-pill__seal img {
    width: 66px;
    height: 66px;
    object-fit: contain;
    display: block;
    border-radius: 50%;
    filter:
      drop-shadow(0 6px 10px rgba(0, 0, 0, 0.38))
      drop-shadow(0 0 2px rgba(212, 165, 76, 0.46));
  }

  .sc-collector-pill__text {
    position: relative;
    z-index: 2;
    margin-left: 76px;
    margin-right: 14px;
    width: calc(100% - 90px);
    min-width: 0;
    color: #D4A54C;
    font-family: inherit;
    font-size: clamp(8px, 2.7vw, 11.8px);
    font-weight: 900;
    line-height: 1.05;
    letter-spacing: clamp(0em, 0.8vw, 0.052em);
    text-transform: uppercase;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    text-align: center;
    text-shadow: 0 1px 0 rgba(0, 0, 0, 0.48);
    word-break: normal;
    overflow-wrap: normal;
  }

  @media (max-width: 430px) {
    .sc-collector-pill {
      min-height: 35px;
    }

    .sc-collector-pill::before {
      left: 31px;
    }

    .sc-collector-pill::after {
      left: 94px;
      right: 12px;
    }

    .sc-collector-pill__text {
      margin-left: 73px;
      margin-right: 12px;
      width: calc(100% - 85px);
    }
  }

  @media (max-width: 360px) {
    .sc-collector-pill {
      min-height: 34px;
    }

    .sc-collector-pill::before {
      left: 29px;
    }

    .sc-collector-pill::after {
      left: 88px;
      right: 10px;
    }

    .sc-collector-pill__seal {
      width: 70px;
      height: 70px;
    }

    .sc-collector-pill__seal::before {
      width: 51px;
      height: 51px;
    }

    .sc-collector-pill__seal img {
      width: 63px;
      height: 63px;
    }

    .sc-collector-pill__text {
      margin-left: 70px;
      margin-right: 10px;
      width: calc(100% - 80px);
    }
  }

  @media (max-width: 320px) {
    .sc-collector-pill__text {
      margin-left: 68px;
      margin-right: 8px;
      width: calc(100% - 76px);
      white-space: normal;
    }
  }
</style>
