{%- comment -%}
  Sports Cave Limited Edition Widget
  Source of truth: Shopify product metafields in namespace sports_cave.
  This snippet does not call Sports Cave OS, Supabase, inventory, or external APIs.
{%- endcomment -%}

{%- liquid
  assign edition_enabled = product.metafields.sports_cave.edition_enabled.value

  if edition_enabled == true or edition_enabled == 'true'
    assign edition_total = product.metafields.sports_cave.edition_total.value | default: 100 | plus: 0
    assign edition_next_number = product.metafields.sports_cave.edition_next_number.value | default: 1 | plus: 0
    assign edition_label = product.metafields.sports_cave.edition_label.value | default: 'Numbered Edition'
    assign status_override = product.metafields.sports_cave.edition_status_override.value | default: '' | strip

    if edition_total < 1
      assign edition_total = 100
    endif

    if edition_next_number < 1
      assign edition_next_number = 1
    endif

    assign edition_remaining = edition_total | minus: edition_next_number | plus: 1

    if edition_remaining < 0
      assign edition_remaining = 0
    endif

    if edition_remaining <= 0
      assign computed_status = 'Sold Out Archive'
    elsif edition_remaining <= 5
      assign computed_status = 'Final Editions'
    elsif edition_remaining <= 12
      assign computed_status = 'Selling Quickly'
    else
      assign computed_status = 'Limited Edition'
    endif

    assign status_text = status_override | default: computed_status
  endif
-%}

{%- if edition_enabled == true or edition_enabled == 'true' -%}
  <section class="sports-cave-edition-widget" aria-label="Sports Cave limited edition status">
    <div class="sports-cave-edition-widget__status">{{ status_text | escape }}</div>
    <div class="sports-cave-edition-widget__title">
      {{ edition_label | escape }} of {{ edition_total }}
    </div>
    <div class="sports-cave-edition-widget__remaining">
      Only {{ edition_remaining }} remaining
    </div>
    <div class="sports-cave-edition-widget__note">
      No reprints once sold out
    </div>
  </section>

  <style>
    .sports-cave-edition-widget,
    .sports-cave-edition-widget * {
      box-sizing: border-box;
    }

    .sports-cave-edition-widget {
      width: 100%;
      margin: 1rem 0;
      padding: 1rem 1.1rem;
      border: 1px solid rgba(212, 165, 76, 0.45);
      border-radius: 8px;
      background:
        linear-gradient(180deg, rgba(245, 242, 234, 0.055), rgba(245, 242, 234, 0) 48%),
        #0B0B0D;
      color: #F5F2EA;
      font-family: inherit;
      box-shadow:
        0 14px 34px rgba(0, 0, 0, 0.24),
        inset 0 1px 0 rgba(245, 242, 234, 0.08);
    }

    .sports-cave-edition-widget__status {
      color: #D4A54C;
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      line-height: 1.2;
      margin-bottom: 0.45rem;
      text-transform: uppercase;
    }

    .sports-cave-edition-widget__title {
      color: #F5F2EA;
      font-size: 1rem;
      font-weight: 800;
      line-height: 1.25;
      margin-bottom: 0.18rem;
    }

    .sports-cave-edition-widget__remaining {
      color: #D4A54C;
      font-size: 0.92rem;
      font-weight: 750;
      line-height: 1.3;
      margin-bottom: 0.34rem;
    }

    .sports-cave-edition-widget__note {
      color: #A6A19A;
      font-size: 0.82rem;
      line-height: 1.35;
    }

    @media screen and (max-width: 749px) {
      .sports-cave-edition-widget {
        padding: 0.92rem 0.95rem;
      }
    }
  </style>
{%- endif -%}
